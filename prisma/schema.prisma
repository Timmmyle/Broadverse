datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id                String   @id @default(uuid())
  email             String?  @unique
  username          String
  isGuest           Boolean  @default(true)
  isPremium         Boolean  @default(false)         // Trạng thái tài khoản Premium
  premiumUntil      DateTime?                         // Thời hạn Premium (null = vĩnh viễn)
  coins             Int      @default(100)
  shells            Int      @default(0)             // Điểm vỏ sò sự kiện mùa hè
  boxOpenings       Int      @default(0)             // Số lần mở hộp quà sự kiện
  level             Int      @default(1)
  exp               Int      @default(0)
  avatarUrl             String?
  lastClaimedDaily      DateTime?                         // Ngày cuối cùng điểm danh nhận quà
  referredBy            String?                         // Username người giới thiệu
  lastClaimedReferral   DateTime?                         // Thời gian cuối nhận thưởng giới thiệu bạn bè
  claimedReferralsCount Int      @default(0)             // Số lượng bạn bè đã nhận thưởng giới thiệu thành công
  lastClaimedEventDaily DateTime?                         // Thời gian cuối nhận thưởng NV Đăng nhập ngày
  lastClaimedEventWin3  DateTime?                         // Thời gian cuối nhận thưởng NV Thắng 3 trận
  lastClaimedEventPlay5 DateTime?                         // Thời gian cuối nhận thưởng NV Chơi 5 trận
  createdAt             DateTime @default(now())

  // Trang trí
  avatarFrame       String   @default("default")     // ID khung avatar đang dùng
  selectedSymbolX   String   @default("X")           // Symbol tùy chỉnh thay thế cho X
  selectedSymbolO   String   @default("O")           // Symbol tùy chỉnh thay thế cho O
  purchasedItems    String[] @default([])            // Danh sách ID vật phẩm đã mua
  
  gamesAsX          GameRoom[] @relation("PlayerX")
  gamesAsO          GameRoom[] @relation("PlayerO")
}

model MatchmakingQueue {
  id        String   @id @default(uuid())
  playerId  String   @unique
  gameType  String   // "TIC_TAC_TOE" hoặc "CARO"
  level     Int
  wager     Int      @default(0)                     // Mức cược Coin mong muốn
  createdAt DateTime @default(now())

  @@index([playerId])
  @@index([gameType, level, wager])
}

model GameRoom {
  id           String   @id @default(uuid())
  gameType     String   // "TIC_TAC_TOE" hoặc "CARO"
  status       String   // "WAITING", "PLAYING", "FINISHED"
  playerXId    String
  playerOId    String?
  turnPlayerId String?
  board        String   // Chuỗi JSON mã hóa bàn cờ, ví dụ: '{"0":"X", "5":"O"}'
  wager        Int      @default(0)                     // Số coin đặt cược của mỗi người chơi
  winnerId     String?
  draw         Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  playerX      User     @relation("PlayerX", fields: [playerXId], references: [id])
  playerO      User?    @relation("PlayerO", fields: [playerOId], references: [id])

  @@index([status])
  @@index([playerXId])
  @@index([playerOId])
}
